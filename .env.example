# ============================================
# ExepaginasWeb - Environment Variables
# Copia este archivo a .env y rellena los valores
# ============================================

# --- GROQ AI (Chatbot + Generador de código) ---
# Obtén tu API key gratis en: https://console.groq.com/keys
GROQ_API_KEY=gsk_tu_api_key_de_groq
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# --- RESEND (Envío de emails desde el formulario de contacto) ---
# Obtén tu API key gratis en: https://resend.com (3000 emails/mes gratis)
RESEND_API_KEY=re_tu_api_key_de_resend
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=tu_email@ejemplo.com

# --- Servidor de desarrollo API ---
API_PORT=3000

