# Servidor
API_PORT=3000
NODE_ENV=development

# Supabase (obligatorio en Vercel para login / panel de clientes)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key
# URL pública del sitio (producción). Debe coincidir con Site URL en Supabase Auth.
VITE_SITE_URL=https://exepaginasweb.com

# IA (Groq)
GROQ_API_KEY=tu_clave_aqui
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# Feature Flags
ENABLE_BETA_CHAT=false

# Mercado Pago (credenciales de producción de https://developers.mercadopago.com)
MERCADOPAGO_ACCESS_TOKEN=APP_USR_xxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR_xxxx

# PayPal (credenciales de https://developer.paypal.com/dashboard)
PAYPAL_CLIENT_ID=xxxx
PAYPAL_CLIENT_SECRET=xxxx

# Resend (emails — requiere dominio verificado)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=contacto@exepaginasweb.com